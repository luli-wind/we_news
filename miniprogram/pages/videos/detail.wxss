.detail-page {
  min-height: 100vh;
  background: #f5f6f8;
  padding-bottom: 140rpx;
}

/* ===== 视频播放器 ===== */
.video-wrap {
  width: 100%;
  background: #000000;
}

.video-player {
  width: 100%;
  height: 450rpx;
}

/* ===== 信息卡片 ===== */
.info-card {
  margin: 20rpx;
  background: #ffffff;
  border-radius: 18rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.video-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  line-height: 1.4;
}

.video-meta {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #e24b4b;
  background: #fef2f2;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

.meta-divider {
  color: #ddd;
}

.video-desc {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #f3f4f6;
}

.desc-line {
  font-size: 28rpx;
  color: #555;
  line-height: 1.7;
  margin-bottom: 6rpx;
}

/* ===== 评论区域 ===== */
.comment-section {
  margin: 0 20rpx;
}

.comment-head {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 14rpx;
}

.comment-item {
  margin-bottom: 12rpx;
  background: #ffffff;
  border-radius: 14rpx;
  padding: 18rpx 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.comment-item--reply {
  margin-left: 48rpx;
  background: #fafbfc;
  border-left: 3rpx solid #e24b4b;
}

.reply-indicator {
  font-size: 20rpx;
  color: #e24b4b;
  margin-top: 4rpx;
  margin-bottom: 4rpx;
}

.reply-to {
  background: #fef2f2;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
}

.comment-top {
  display: flex;
  align-items: center;
}

.comment-avatar {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.comment-user {
  margin-left: 10rpx;
  font-size: 24rpx;
  color: #1a1a2e;
  font-weight: 600;
}

.comment-content {
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #333;
}

.comment-bottom {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.comment-time {
  font-size: 20rpx;
  color: #bbb;
}

.reply-btn {
  font-size: 20rpx;
  color: #e24b4b;
  font-weight: 500;
}

.delete-btn {
  font-size: 20rpx;
  color: #bbb;
  margin-left: 8rpx;
}

.no-comment {
  text-align: center;
  padding: 40rpx 0;
  color: #bbb;
  font-size: 24rpx;
}

/* ===== 评论输入 ===== */
.comment-input-box {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #ffffff;
  border-top: 1rpx solid #eee;
  padding: 12rpx 20rpx calc(12rpx + env(safe-area-inset-bottom));
}

.reply-tip {
  font-size: 22rpx;
  color: #666;
  margin-bottom: 8rpx;
  display: flex;
  align-items: center;
}

.cancel-reply {
  color: #e24b4b;
  margin-left: 12rpx;
}

.input-row {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.comment-input {
  flex: 1;
  background: #f5f6f8;
  border-radius: 999rpx;
  height: 64rpx;
  padding: 0 22rpx;
  font-size: 26rpx;
}

.send-btn {
  min-width: 120rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #e24b4b, #c53030);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  padding: 0;
}

.send-btn::after {
  border: none;
}
