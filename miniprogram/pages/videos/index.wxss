.video-page {
  min-height: 100vh;
  background: #f3f4f6;
  padding-bottom: 110rpx;
}

.video-head {
  background: #ffffff;
  padding: 16rpx 20rpx;
}

.url-bar {
  display: flex;
  align-items: center;
  background: #f3f4f6;
  border-radius: 999rpx;
  padding: 0 18rpx;
  height: 62rpx;
}

.url-prefix {
  color: #6b7280;
  font-size: 24rpx;
  margin-right: 8rpx;
}

.url-input {
  flex: 1;
  font-size: 25rpx;
}

.featured-card {
  margin: 16rpx 20rpx;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
}

.featured-player {
  width: 100%;
  height: 380rpx;
}

.featured-title {
  padding: 20rpx 20rpx 8rpx;
  font-size: 48rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #1f2937;
}

.featured-meta {
  padding: 0 20rpx;
  color: #9ca3af;
  font-size: 24rpx;
}

.op-row {
  margin-top: 18rpx;
  padding: 0 20rpx;
  display: flex;
  gap: 14rpx;
}

.op-btn {
  border: 1rpx solid #cbd5e1;
  border-radius: 999rpx;
  padding: 10rpx 20rpx;
  color: #475569;
  font-size: 24rpx;
}

.author-row {
  margin-top: 18rpx;
  padding: 0 20rpx 20rpx;
  display: flex;
  align-items: center;
}

.author-dot {
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  background: #f59e0b;
}

.author-name {
  margin-left: 12rpx;
  font-size: 30rpx;
  color: #1f2937;
  font-weight: 600;
}

.video-item {
  margin: 0 20rpx 12rpx;
  background: #ffffff;
  border-radius: 14rpx;
  padding: 18rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.video-item-main {
  flex: 1;
}

.video-item-title {
  font-size: 40rpx;
  line-height: 1.35;
  color: #1f2937;
  font-weight: 650;
}

.video-item-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #9ca3af;
}

.video-item-thumb {
  width: 206rpx;
  height: 138rpx;
  border-radius: 10rpx;
}

.foot-input {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #ffffff;
  border-top: 1rpx solid #e5e7eb;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 14rpx 20rpx calc(14rpx + env(safe-area-inset-bottom));
}

.comment-input {
  flex: 1;
  background: #f3f4f6;
  border-radius: 999rpx;
  height: 62rpx;
  line-height: 62rpx;
  color: #9ca3af;
  font-size: 24rpx;
  padding: 0 22rpx;
}

.foot-icons {
  color: #475569;
  font-size: 40rpx;
  letter-spacing: 8rpx;
}