.video-page {
  min-height: 100vh;
  background: #f5f6f8;
  padding-bottom: 120rpx;
}

/* ===== 头部 ===== */
.video-head {
  background: linear-gradient(135deg, #e24b4b 0%, #c53030 100%);
  padding: 28rpx 24rpx 24rpx;
}

.video-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 999rpx;
  padding: 0 20rpx;
  height: 64rpx;
}

.search-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.search-input {
  flex: 1;
  font-size: 24rpx;
  color: #333;
}

/* ===== 精选视频 ===== */
.featured-card {
  margin: 16rpx 20rpx;
  background: #ffffff;
  border-radius: 18rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.15s;
}

.featured-card:active {
  transform: scale(0.985);
}

.featured-player {
  width: 100%;
  height: 420rpx;
  background: #000;
}

.featured-title {
  padding: 20rpx 22rpx 8rpx;
  font-size: 34rpx;
  line-height: 1.4;
  font-weight: 700;
  color: #1a1a2e;
}

.featured-meta {
  padding: 0 22rpx;
  color: #999;
  font-size: 24rpx;
}

.action-row {
  margin-top: 16rpx;
  padding: 0 22rpx;
  display: flex;
  gap: 14rpx;
}

.action-btn {
  border: 1rpx solid #eee;
  border-radius: 999rpx;
  padding: 10rpx 22rpx;
  color: #666;
  font-size: 24rpx;
  background: #fafbfc;
  transition: all 0.15s;
}

.author-row {
  margin-top: 16rpx;
  padding: 16rpx 22rpx 22rpx;
  display: flex;
  align-items: center;
  border-top: 1rpx solid #f5f6f8;
}

.author-avatar {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.author-name {
  margin-left: 12rpx;
  font-size: 26rpx;
  color: #1a1a2e;
  font-weight: 600;
}

/* ===== 推荐列表 ===== */
.section-header {
  padding: 24rpx 24rpx 8rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.section-dot {
  width: 8rpx;
  height: 28rpx;
  border-radius: 999rpx;
  background: #e24b4b;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.video-card {
  margin: 0 20rpx 14rpx;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.15s;
}

.video-card:active {
  transform: scale(0.985);
}

.video-thumb {
  width: 100%;
  height: 340rpx;
  background: #eef0f3;
  position: relative;
}

.video-info {
  padding: 16rpx 20rpx 20rpx;
}

.video-card-title {
  font-size: 30rpx;
  line-height: 1.4;
  color: #1a1a2e;
  font-weight: 600;
}

.video-card-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #999;
}

.empty-state {
  text-align: center;
  color: #999;
  padding: 80rpx 0;
  font-size: 26rpx;
}
