<view class="detail-page">
  <view class="article-wrap">
    <view class="article-title">{{detail.title}}</view>

    <view class="author-row">
      <view class="author-avatar">{{authorName.substring(0, 1)}}</view>
      <view class="author-info">
        <view class="author-name">{{authorName}}</view>
        <view class="author-time">{{publishTimeText}}</view>
      </view>
    </view>

    <image wx:if="{{detail.coverUrl}}" class="cover-image" src="{{detail.coverUrl}}" mode="widthFix" lazy-load data-url="{{detail.coverUrl}}" bindtap="previewImage" binderror="onCoverError" />

    <block wx:for="{{paragraphs}}" wx:key="index">
      <view class="paragraph">{{item}}</view>
    </block>

    <block wx:for="{{mediaImages}}" wx:key="id">
      <image wx:if="{{index > 0 || !detail.coverUrl || item.url !== detail.coverUrl}}" class="content-image" src="{{item.url}}" mode="widthFix" lazy-load data-url="{{item.url}}" bindtap="previewImage" binderror="onImageError" data-index="{{index}}" />
    </block>

    <view class="tag-row">
      <text class="tag-item">{{detail.category || '新闻'}}</text>
    </view>

    <view class="action-row">
      <view class="action-item action-item--like">
        <text class="action-icon">❤️</text>
        <text>点赞</text>
      </view>
      <view class="action-item" bindtap="toggleFavorite">
        <text class="action-icon">{{favorited ? '⭐' : '☆'}}</text>
        <text>{{favoriteButtonText}}</text>
      </view>
    </view>
  </view>

  <view class="comment-section">
    <view class="comment-head">评论 {{commentCount}}</view>

    <block wx:for="{{comments}}" wx:key="id">
      <view class="comment-item {{item.isReply ? 'comment-item--reply' : ''}}">
        <view class="comment-top">
          <view class="comment-avatar">{{item.displayName.substring(0, 1)}}</view>
          <view class="comment-user">{{item.displayName}}</view>
        </view>
        <view wx:if="{{item.isReply}}" class="reply-indicator">
          <text class="reply-to">回复 {{item.parentId}}</text>
        </view>
        <view class="comment-content">{{item.content}}</view>
        <view class="comment-bottom">
          <view class="comment-time">{{item.timeText}}</view>
          <view class="reply-btn" data-id="{{item.id}}" data-nickname="{{item.displayName}}" bindtap="selectReply">回复</view>
          <view class="delete-btn" data-id="{{item.id}}" catchtap="deleteComment">删除</view>
        </view>
      </view>
    </block>

    <view wx:if="{{!comments.length}}" class="no-comment">暂无评论，写下第一条评论吧</view>
  </view>

  <view class="comment-input-box">
    <view wx:if="{{replyHint}}" class="reply-tip">
      <text>{{replyHint}}</text>
      <text class="cancel-reply" bindtap="clearReply">取消</text>
    </view>
    <view class="input-row">
      <input class="comment-input" placeholder="写下你的评论..." value="{{commentText}}" bindinput="onCommentInput" confirm-type="send" bindconfirm="submitComment" />
      <button class="send-btn" bindtap="submitComment">发送</button>
    </view>
  </view>
</view>
