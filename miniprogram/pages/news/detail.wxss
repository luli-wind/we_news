.detail-page {
  min-height: 100vh;
  background: #f5f6f8;
  padding: 20rpx 20rpx 160rpx;
  box-sizing: border-box;
}

/* ===== 文章卡片 ===== */
.article-wrap {
  background: #ffffff;
  border-radius: 18rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.article-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #1a1a2e;
  line-height: 1.4;
}

.author-row {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
}

.author-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #e24b4b, #f59e0b);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.author-info {
  margin-left: 14rpx;
}

.author-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.author-time {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.cover-image {
  margin-top: 20rpx;
  width: 100%;
  border-radius: 12rpx;
  background: #f0f0f0;
}

.content-image {
  margin-top: 16rpx;
  width: 100%;
  border-radius: 12rpx;
  background: #f0f0f0;
}

.paragraph {
  margin-top: 20rpx;
  font-size: 32rpx;
  line-height: 1.9;
  color: #374151;
  text-align: justify;
  text-indent: 2em;
}

.tag-row {
  margin-top: 28rpx;
  display: flex;
  gap: 12rpx;
}

.tag-item {
  background: #fef2f2;
  color: #e24b4b;
  font-size: 22rpx;
  font-weight: 500;
  border-radius: 999rpx;
  padding: 8rpx 20rpx;
}

/* ===== 点赞收藏 ===== */
.action-row {
  margin-top: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid #f3f4f6;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #666;
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  background: #f8fafc;
}

.action-icon {
  font-size: 30rpx;
}

/* ===== 评论区域 ===== */
.comment-section {
  margin-top: 20rpx;
}

.comment-head {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 12rpx;
  padding: 0 4rpx;
}

.comment-item {
  margin-bottom: 12rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx 22rpx;
}

.comment-top {
  display: flex;
  align-items: center;
}

.comment-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.comment-user {
  margin-left: 12rpx;
  font-size: 26rpx;
  color: #1a1a2e;
  font-weight: 600;
}

.comment-like {
  margin-left: auto;
  font-size: 22rpx;
  color: #999;
}

.comment-content {
  margin-top: 12rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
}

.comment-bottom {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.comment-time {
  font-size: 22rpx;
  color: #bbb;
}

.reply-btn {
  font-size: 22rpx;
  color: #e24b4b;
  font-weight: 500;
}

.delete-btn {
  font-size: 22rpx;
  color: #bbb;
  margin-left: 8rpx;
}

/* ===== 回复样式 ===== */
.comment-item--reply {
  margin-left: 48rpx;
  background: #fafbfc;
  border-left: 3rpx solid #e24b4b;
}

.reply-indicator {
  font-size: 20rpx;
  color: #e24b4b;
  margin-top: 4rpx;
  margin-bottom: 4rpx;
}

.reply-to {
  background: #fef2f2;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
}

.no-comment {
  text-align: center;
  padding: 40rpx 0;
  color: #bbb;
  font-size: 26rpx;
}

/* ===== 评论输入 ===== */
.comment-input-box {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #ffffff;
  border-top: 1rpx solid #eee;
  padding: 12rpx 20rpx calc(12rpx + env(safe-area-inset-bottom));
}

.reply-tip {
  font-size: 22rpx;
  color: #666;
  margin-bottom: 8rpx;
  display: flex;
  align-items: center;
}

.cancel-reply {
  color: #e24b4b;
  margin-left: 12rpx;
}

.input-row {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.comment-input {
  flex: 1;
  background: #f5f6f8;
  border-radius: 999rpx;
  height: 66rpx;
  padding: 0 22rpx;
  font-size: 26rpx;
}

.send-btn {
  min-width: 120rpx;
  height: 66rpx;
  line-height: 66rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #e24b4b, #c53030);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  padding: 0;
}

.send-btn::after {
  border: none;
}
