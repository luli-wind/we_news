.detail-page {
  min-height: 100vh;
  background: #f3f4f6;
  padding: 20rpx 20rpx 150rpx;
  box-sizing: border-box;
}

.article-wrap {
  background: #ffffff;
  border-radius: 18rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.06);
}

.article-title {
  font-size: 46rpx;
  font-weight: 800;
  color: #1f2937;
  line-height: 1.35;
}

.author-row {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
}

.author-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f59e0b;
}

.author-info {
  margin-left: 12rpx;
}

.author-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #111827;
}

.author-time {
  font-size: 22rpx;
  color: #9ca3af;
  margin-top: 4rpx;
}

.paragraph {
  margin-top: 20rpx;
  font-size: 32rpx;
  line-height: 1.9;
  color: #374151;
  text-align: justify;
}

.tag-row {
  margin-top: 28rpx;
  display: flex;
  gap: 12rpx;
}

.tag-item {
  background: #f3f4f6;
  color: #6b7280;
  font-size: 22rpx;
  border-radius: 999rpx;
  padding: 8rpx 18rpx;
}

.vote-row {
  margin-top: 28rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.vote-btn {
  border: 1rpx solid #d1d5db;
  border-radius: 999rpx;
  padding: 12rpx 18rpx;
  color: #4b5563;
  font-size: 24rpx;
}

.vote-btn--up {
  color: #2563eb;
}

.vote-btn--down {
  color: #6b7280;
}

.collect-btn {
  margin-left: auto;
  background: #fef2f2;
  color: #dc2626;
  border: 1rpx solid #fecaca;
  border-radius: 999rpx;
  padding: 12rpx 22rpx;
  font-size: 24rpx;
}

.comment-head {
  margin-top: 20rpx;
  margin-bottom: 8rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2937;
}

.comment-item {
  margin-top: 14rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.comment-top {
  display: flex;
  align-items: center;
}

.comment-avatar {
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  background: #ef4444;
}

.comment-user {
  margin-left: 10rpx;
  font-size: 25rpx;
  color: #374151;
  font-weight: 600;
}

.comment-like {
  margin-left: auto;
  font-size: 22rpx;
  color: #9ca3af;
}

.comment-content {
  margin-top: 12rpx;
  font-size: 30rpx;
  line-height: 1.6;
  color: #1f2937;
}

.comment-time {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #9ca3af;
}

.reply-btn {
  margin-top: 8rpx;
  color: #2563eb;
  font-size: 24rpx;
}

.comment-input-box {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #ffffff;
  border-top: 1rpx solid #e5e7eb;
  padding: 10rpx 20rpx calc(10rpx + env(safe-area-inset-bottom));
}

.reply-tip {
  font-size: 22rpx;
  color: #6b7280;
  margin-bottom: 8rpx;
}

.reply-tip text {
  color: #ef4444;
  margin-left: 8rpx;
}

.input-row {
  display: flex;
  gap: 10rpx;
  align-items: center;
}

.comment-input {
  flex: 1;
  background: #f3f4f6;
  border-radius: 999rpx;
  height: 64rpx;
  padding: 0 22rpx;
  font-size: 26rpx;
}

.send-btn {
  min-width: 120rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 999rpx;
  background: #d73d3d;
  color: #ffffff;
  font-size: 24rpx;
  padding: 0;
}

.send-btn::after {
  border: none;
}