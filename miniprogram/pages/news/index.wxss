.news-page {
  min-height: 100vh;
  background: #f3f4f6;
}

.top-bar {
  padding: 18rpx 20rpx 0;
  background: linear-gradient(180deg, #d83a3a 0%, #d83a3a 70%, #ffffff 70%, #ffffff 100%);
}

.brand-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.brand-title {
  color: #ffffff;
  font-size: 42rpx;
  font-weight: 800;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 999rpx;
  padding: 0 24rpx;
  height: 68rpx;
}

.search-mark {
  color: #6b7280;
  font-size: 24rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #111827;
}

.tab-scroll {
  margin-top: 20rpx;
  white-space: nowrap;
  width: 100%;
}

.tab-list {
  display: inline-flex;
  align-items: center;
  gap: 24rpx;
  padding: 0 8rpx 14rpx;
}

.tab-item {
  font-size: 33rpx;
  color: #4b5563;
  padding-bottom: 8rpx;
  border-bottom: 4rpx solid transparent;
}

.tab-item--active {
  color: #d73d3d;
  font-weight: 700;
  border-bottom-color: #d73d3d;
}

.update-tip {
  background: #dcecff;
  color: #2a6ca8;
  text-align: center;
  font-size: 24rpx;
  padding: 12rpx;
}

.hero-card {
  margin: 18rpx 20rpx;
  background: #ffffff;
  border-radius: 18rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 22rpx rgba(15, 23, 42, 0.08);
}

.hero-image {
  width: 100%;
  height: 340rpx;
}

.hero-title {
  padding: 20rpx 20rpx 8rpx;
  font-size: 38rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #1f2937;
}

.hero-meta {
  padding: 0 20rpx 20rpx;
  font-size: 24rpx;
  color: #9ca3af;
}

.feed-card {
  margin: 0 20rpx 16rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(17, 24, 39, 0.05);
}

.feed-title {
  font-size: 38rpx;
  line-height: 1.4;
  font-weight: 650;
  color: #1f2937;
}

.single-row {
  margin-top: 14rpx;
  display: flex;
  gap: 16rpx;
}

.single-summary {
  flex: 1;
  color: #4b5563;
  font-size: 26rpx;
  line-height: 1.5;
  max-height: 150rpx;
  overflow: hidden;
}

.single-thumb {
  width: 210rpx;
  height: 150rpx;
  border-radius: 12rpx;
}

.triple-row {
  margin-top: 16rpx;
  display: flex;
  gap: 10rpx;
}

.triple-thumb {
  flex: 1;
  height: 150rpx;
  border-radius: 10rpx;
}

.feed-meta {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #9ca3af;
  font-size: 24rpx;
}

.hot-mark {
  display: inline-block;
  font-size: 20rpx;
  color: #ef4444;
  border: 1rpx solid #ef4444;
  border-radius: 6rpx;
  padding: 2rpx 6rpx;
  line-height: 1;
}

.empty-block {
  text-align: center;
  color: #9ca3af;
  padding: 60rpx 0 80rpx;
  font-size: 28rpx;
}