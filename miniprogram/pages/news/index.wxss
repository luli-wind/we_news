.news-page {
  min-height: 100vh;
  background: #f5f6f8;
  padding-bottom: 120rpx;
}

/* ===== 顶部导航 ===== */
.top-bar {
  background: linear-gradient(135deg, #e24b4b 0%, #c53030 100%);
  padding: 24rpx 24rpx 0;
  position: sticky;
  top: 0;
  z-index: 100;
}

.brand-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.brand-title {
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  flex-shrink: 0;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 999rpx;
  padding: 0 20rpx;
  height: 64rpx;
}

.search-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 24rpx;
  color: #333;
}

.refresh-btn {
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-left: 12rpx;
  transition: transform 0.2s;
}

.refresh-btn:active {
  transform: rotate(180deg);
}

/* ===== 频道切换 ===== */
.channel-tabs {
  display: flex;
  gap: 44rpx;
  margin-top: 18rpx;
  padding-bottom: 4rpx;
}

.channel-tab {
  position: relative;
  padding: 0 4rpx 14rpx;
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 500;
  transition: all 0.2s;
}

.channel-tab--active {
  color: #ffffff;
  font-weight: 700;
  font-size: 34rpx;
}

.tab-indicator {
  position: absolute;
  bottom: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: #ffffff;
  border-radius: 999rpx;
  animation: slideIn 0.2s ease;
}

@keyframes slideIn {
  from { width: 0; opacity: 0; }
  to { width: 40rpx; opacity: 1; }
}

/* ===== 头条卡片 ===== */
.feed-card {
  margin: 14rpx 20rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 22rpx;
  display: flex;
  gap: 18rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.15s;
}

.feed-card:active {
  transform: scale(0.985);
}

.feed-body {
  flex: 1;
  min-width: 0;
}

.feed-title {
  font-size: 32rpx;
  line-height: 1.45;
  font-weight: 600;
  color: #1a1a2e;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.feed-summary {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #888;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.feed-thumb {
  width: 200rpx;
  height: 140rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #eef0f3;
}

/* ===== 动态卡片 ===== */
.dynamic-card {
  margin: 14rpx 20rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 22rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.15s;
}

.dynamic-card:active {
  transform: scale(0.985);
}

.dynamic-header {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.dynamic-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.dynamic-meta {
  flex: 1;
}

.dynamic-author {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.dynamic-time {
  font-size: 22rpx;
  color: #aaa;
  margin-top: 4rpx;
}

.dynamic-title {
  margin-top: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
  line-height: 1.4;
}

.dynamic-summary {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.dynamic-cover {
  margin-top: 14rpx;
  width: 100%;
  height: 360rpx;
  border-radius: 12rpx;
  background: #eef0f3;
}

/* ===== 加载更多 ===== */
.load-more {
  text-align: center;
  padding: 20rpx 0 40rpx;
  color: #bbb;
  font-size: 24rpx;
}

/* ===== 空状态 ===== */
.empty-block {
  text-align: center;
  padding: 100rpx 40rpx 80rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #555;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 24rpx;
}

.empty-action {
  display: inline-block;
  background: linear-gradient(135deg, #e24b4b, #c53030);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 14rpx 36rpx;
  border-radius: 999rpx;
  box-shadow: 0 8rpx 20rpx rgba(226, 75, 75, 0.3);
}

/* ===== 加载 ===== */
.loading-block {
  text-align: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 26rpx;
}

.loading-spinner {
  width: 44rpx;
  height: 44rpx;
  border: 4rpx solid #eef0f3;
  border-top-color: #e24b4b;
  border-radius: 50%;
  margin: 0 auto 14rpx;
  animation: spin 0.7s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
