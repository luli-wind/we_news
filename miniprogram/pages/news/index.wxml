<view class="news-page">
  <view class="top-bar">
    <view class="brand-row">
      <view class="brand-title">今日资讯</view>
      <view class="search-box">
        <text class="search-icon">🔍</text>
        <input class="search-input" placeholder="搜索新闻" value="{{keyword}}" bindinput="onKeywordInput" confirm-type="search" bindconfirm="onConfirmSearch" />
      </view>
      <view class="refresh-btn" bindtap="onRefreshTap">🔄</view>
    </view>

    <view class="channel-tabs">
      <view class="channel-tab {{channel === 'headline' ? 'channel-tab--active' : ''}}" data-channel="headline" bindtap="switchChannel">
        <text class="tab-icon">📰</text>
        <text class="tab-label">头条</text>
      </view>
      <view class="channel-tab {{channel === 'dynamic' ? 'channel-tab--active' : ''}}" data-channel="dynamic" bindtap="switchChannel">
        <text class="tab-icon">💬</text>
        <text class="tab-label">动态</text>
      </view>
    </view>
  </view>

  <!-- 头条频道 -->
  <view wx:if="{{channel === 'headline'}}">
    <block wx:if="{{loading && headline.feed.length === 0}}">
      <view class="skeleton-card" wx:for="{{[1,2,3,4,5]}}" wx:key="*this">
        <view class="skeleton-body">
          <view class="skeleton-line skeleton-line--long"></view>
          <view class="skeleton-line skeleton-line--short"></view>
        </view>
        <view class="skeleton-thumb"></view>
      </view>
    </block>

    <block wx:for="{{headline.feed}}" wx:key="id">
      <view class="feed-card {{!item.coverUrl ? 'feed-card--no-thumb' : ''}}" data-id="{{item.id}}" bindtap="goDetail">
        <view class="feed-body">
          <view class="feed-title">
            <text wx:for="{{item.titleParts}}" wx:key="index" wx:for-item="part" style="{{part.hl ? 'color:#e24b4b' : ''}}">{{part.text}}</text>
          </view>
          <view wx:if="{{item.summary}}" class="feed-summary">{{item.summary}}</view>
        </view>
        <image wx:if="{{item.coverUrl}}" class="feed-thumb" src="{{item.coverUrl}}" mode="aspectFill" lazy-load binderror="onCoverError" data-index="{{index}}" data-channel="headline" />
      </view>
    </block>

    <view wx:if="{{headline.showEmpty && !loading}}" class="empty-block">
      <view class="empty-icon">📰</view>
      <view class="empty-text">暂无头条新闻</view>
      <view class="empty-sub">去动态频道看看大家的分享吧</view>
    </view>

    <view wx:if="{{loading && headline.feed.length > 0}}" class="load-more">
      <text>加载中...</text>
    </view>
    <view wx:elif="{{headline.hasMore && headline.feed.length > 0}}" class="load-more" bindtap="loadMore">
      <text>加载更多</text>
    </view>
  </view>

  <!-- 动态频道 -->
  <view wx:if="{{channel === 'dynamic'}}">
    <block wx:if="{{loading && dynamic.feed.length === 0}}">
      <view class="skeleton-card" wx:for="{{[1,2,3,4,5]}}" wx:key="*this">
        <view class="skeleton-body">
          <view class="skeleton-line skeleton-line--long"></view>
          <view class="skeleton-line skeleton-line--short"></view>
        </view>
        <view class="skeleton-thumb"></view>
      </view>
    </block>

    <block wx:for="{{dynamic.feed}}" wx:key="id">
      <view class="dynamic-card" data-id="{{item.id}}" bindtap="goDetail">
        <view class="dynamic-header">
          <view class="dynamic-avatar">{{item.sourceText.substring(0, 1)}}</view>
          <view class="dynamic-meta">
            <view class="dynamic-author">{{item.sourceText}}</view>
            <view class="dynamic-time">{{item.relativeTime}}</view>
          </view>
        </view>
        <view class="dynamic-title">
          <text wx:for="{{item.titleParts}}" wx:key="index" wx:for-item="part" style="{{part.hl ? 'color:#e24b4b' : ''}}">{{part.text}}</text>
        </view>
        <view wx:if="{{item.summary}}" class="dynamic-summary">{{item.summary}}</view>
        <image wx:if="{{item.coverUrl}}" class="dynamic-cover" src="{{item.coverUrl}}" mode="aspectFill" lazy-load />
      </view>
    </block>

    <view wx:if="{{dynamic.showEmpty && !loading}}" class="empty-block">
      <view class="empty-icon">💬</view>
      <view class="empty-text">暂无动态</view>
      <view class="empty-sub">去发布第一条</view>
      <view class="empty-action" bindtap="goSubmit">前往创作中心</view>
    </view>

    <view wx:if="{{loading && dynamic.feed.length > 0}}" class="load-more">
      <text>加载中...</text>
    </view>
    <view wx:elif="{{dynamic.hasMore && dynamic.feed.length > 0}}" class="load-more" bindtap="loadMore">
      <text>加载更多</text>
    </view>
  </view>
</view>
