.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #e24b4b 0%, #c53030 40%, #f5f6f8 40%, #f5f6f8 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.login-card {
  width: 100%;
  max-width: 600rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx 36rpx 40rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.12);
  text-align: center;
}

.logo-area {
  margin-bottom: 36rpx;
}

.logo-icon {
  font-size: 96rpx;
  margin-bottom: 16rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: 800;
  color: #1a1a2e;
  letter-spacing: 4rpx;
}

.app-desc {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #999;
}

.features {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  margin-bottom: 36rpx;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  color: #888;
}

.feature-icon {
  font-size: 40rpx;
}

.user-info-area {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding: 16rpx;
  background: #f8fafc;
  border-radius: 16rpx;
}

.user-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 3rpx solid #e24b4b;
}

.user-avatar-placeholder {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #e24b4b, #f59e0b);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-nickname {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.auth-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 14rpx;
  background: #f8fafc;
  color: #555;
  font-size: 28rpx;
  border: 2rpx dashed #d1d5db;
  margin-bottom: 20rpx;
}

.auth-btn::after {
  border: none;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 14rpx;
  background: linear-gradient(135deg, #07c160, #06ad56);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.35);
}

.login-btn[disabled] {
  opacity: 0.6;
}

.login-btn::after {
  border: none;
}

.privacy-tip {
  margin-top: 24rpx;
  font-size: 22rpx;
  color: #ccc;
}
