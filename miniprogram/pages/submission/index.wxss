.submit-page {
  min-height: 100vh;
  background: #f5f6f8;
  padding-bottom: 140rpx;
}

/* ===== 头部 ===== */
.submit-header {
  background: linear-gradient(135deg, #e24b4b 0%, #c53030 100%);
  padding: 32rpx 28rpx 28rpx;
  color: #ffffff;
}

.submit-header-title {
  font-size: 44rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.submit-header-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  opacity: 0.85;
}

/* ===== 编辑卡片 ===== */
.editor-card {
  margin: 20rpx;
  background: #ffffff;
  border-radius: 18rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

/* ===== 错误提示 ===== */
.error-banner {
  display: flex;
  align-items: center;
  padding: 16rpx 18rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  font-size: 24rpx;
}

.error-banner--validation {
  background: #fff7ed;
  border: 1rpx solid #fed7aa;
}

.error-banner--validation .error-text { color: #c2410c; }

.error-banner--auth {
  background: #fef2f2;
  border: 1rpx solid #fecaca;
}

.error-banner--auth .error-text { color: #dc2626; }

.error-banner--network {
  background: #eff6ff;
  border: 1rpx solid #bfdbfe;
}

.error-banner--network .error-text { color: #2563eb; }

.error-banner--error {
  background: #fef2f2;
  border: 1rpx solid #fecaca;
}

.error-banner--error .error-text { color: #dc2626; }

.error-text {
  flex: 1;
  font-size: 24rpx;
}

.error-retry {
  color: #2563eb;
  font-weight: 600;
  padding: 4rpx 14rpx;
  margin-left: 12rpx;
}

.error-dismiss {
  margin-left: 12rpx;
  color: #999;
  font-size: 28rpx;
  padding: 4rpx 8rpx;
}

/* ===== 表单字段 ===== */
.field-group {
  margin-bottom: 24rpx;
}

.field-label {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.label-text {
  font-size: 28rpx;
  color: #1a1a2e;
  font-weight: 600;
}

.label-required {
  color: #e24b4b;
  font-size: 28rpx;
  margin-left: 4rpx;
}

.label-hint {
  margin-left: auto;
  font-size: 22rpx;
  color: #bbb;
}

.field-input {
  height: 72rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  border: 1rpx solid #e5e7eb;
  padding: 0 18rpx;
  font-size: 28rpx;
  color: #1a1a2e;
  box-sizing: border-box;
}

.field-input:focus {
  border-color: #e24b4b;
  background: #ffffff;
}

.field-textarea {
  width: 100%;
  height: 300rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  border: 1rpx solid #e5e7eb;
  padding: 16rpx 18rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #1a1a2e;
  line-height: 1.6;
}

/* ===== 媒体上传 ===== */
.media-wrap {
  margin-top: 6rpx;
}

.upload-box {
  width: 200rpx;
  height: 200rpx;
  border-radius: 14rpx;
  border: 2rpx dashed #d1d5db;
  background: #f8fafc;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.upload-icon {
  font-size: 56rpx;
  margin-bottom: 8rpx;
}

.upload-tip {
  font-size: 24rpx;
  color: #999;
}

.media-box {
  width: 320rpx;
  height: 200rpx;
  border-radius: 14rpx;
  overflow: hidden;
  position: relative;
  background: #f3f4f6;
}

.media-image,
.media-video {
  width: 100%;
  height: 100%;
}

.remove-media {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  text-align: center;
  line-height: 40rpx;
  background: rgba(0, 0, 0, 0.55);
  color: #ffffff;
  font-size: 22rpx;
}

.upload-status {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 12rpx;
  color: #e24b4b;
  font-size: 24rpx;
}

.upload-spinner {
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid #fecaca;
  border-top-color: #e24b4b;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ===== 发布按钮 ===== */
.submit-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #ffffff;
  border-top: 1rpx solid #eee;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  z-index: 50;
}

.submit-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 14rpx;
  background: linear-gradient(135deg, #e24b4b 0%, #c53030 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  box-shadow: 0 8rpx 20rpx rgba(226, 75, 75, 0.35);
}

.submit-btn[disabled] {
  opacity: 0.6;
}

.submit-btn::after {
  border: none;
}
