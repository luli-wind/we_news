.me-page {
  min-height: 100vh;
  background: #eef1f5;
  padding: 20rpx;
  box-sizing: border-box;
}

.profile-head {
  background: linear-gradient(140deg, #2b2f38 0%, #40434b 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  color: #ffffff;
}

.profile-row {
  display: flex;
  align-items: center;
}

.avatar-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #2ea4e6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  font-weight: 700;
}

.user-info {
  margin-left: 20rpx;
}

.user-name {
  font-size: 46rpx;
  font-weight: 700;
}

.user-role {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
}

.arrow {
  margin-left: auto;
  font-size: 42rpx;
  color: rgba(255, 255, 255, 0.6);
}

.quick-grid {
  margin-top: 16rpx;
  background: #ffffff;
  border-radius: 16rpx;
  display: flex;
  padding: 10rpx 0;
}

.quick-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
}

.quick-icon {
  font-size: 50rpx;
  color: #5d6b7b;
}

.quick-title {
  margin-top: 8rpx;
  font-size: 28rpx;
  color: #111827;
}

.quick-num {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #9ca3af;
}

.menu-card {
  margin-top: 18rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 34rpx;
  display: flex;
  align-items: center;
}

.menu-list {
  margin-top: 18rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.menu-row {
  background: #ffffff;
  padding: 24rpx;
  font-size: 34rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #edf0f2;
}

.menu-row:last-child {
  border-bottom: none;
}

.menu-arrow {
  margin-left: auto;
  color: #94a3b8;
  font-size: 36rpx;
}