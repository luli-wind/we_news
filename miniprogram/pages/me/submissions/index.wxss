.submissions-page {
  min-height: 100vh;
  background: #f5f6f8;
  padding: 0 20rpx 40rpx;
}

/* ===== 头部 ===== */
.page-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 24rpx 4rpx 16rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #1a1a2e;
}

.page-count {
  font-size: 24rpx;
  color: #999;
}

/* ===== 加载 ===== */
.loading-state {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 26rpx;
}

.loading-dot {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #e5e7eb;
  border-top-color: #e24b4b;
  border-radius: 50%;
  margin: 0 auto 12rpx;
  animation: spin 0.7s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ===== 投稿卡片 ===== */
.submission-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-status {
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

.status--pending {
  background: #fef3c7;
  color: #b45309;
}

.status--approved {
  background: #d1fae5;
  color: #065f46;
}

.status--rejected {
  background: #fee2e2;
  color: #b91c1c;
}

.card-time {
  font-size: 22rpx;
  color: #bbb;
}

.card-title {
  margin-top: 14rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
  line-height: 1.4;
}

.card-content {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.card-media {
  margin-top: 12rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f3f4f6;
}

.card-media-img {
  width: 100%;
  height: 320rpx;
}

.card-media-video {
  width: 100%;
  height: 320rpx;
}

/* ===== 驳回原因 ===== */
.reject-reason {
  margin-top: 14rpx;
  background: #fef2f2;
  border-radius: 10rpx;
  padding: 14rpx 16rpx;
  border-left: 4rpx solid #ef4444;
}

.reject-label {
  font-size: 22rpx;
  color: #ef4444;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.reject-text {
  font-size: 24rpx;
  color: #b91c1c;
  line-height: 1.5;
}

/* ===== 操作按钮 ===== */
.card-actions {
  margin-top: 16rpx;
  display: flex;
  gap: 14rpx;
  justify-content: flex-end;
}

.action-btn {
  font-size: 24rpx;
  font-weight: 600;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
}

.action-btn--view {
  color: #2563eb;
  background: #eff6ff;
  border: 1rpx solid #bfdbfe;
}

.action-btn--resubmit {
  color: #ffffff;
  background: linear-gradient(135deg, #e24b4b, #c53030);
}

/* ===== 空状态 ===== */
.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-title {
  font-size: 30rpx;
  color: #555;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: #999;
}
