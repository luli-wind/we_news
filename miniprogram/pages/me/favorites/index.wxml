<view class="container">
  <view class="section-head">收藏列表</view>

  <block wx:for="{{list}}" wx:key="id">
    <view class="list-item" data-id="{{item.id}}" bindtap="goDetail">
      <view class="thumb-slot"></view>
      <view class="item-main">
        <view class="item-title">{{item.title}}</view>
      </view>
      <view class="star" data-id="{{item.id}}" catchtap="unfavorite">已收藏</view>
    </view>
  </block>

  <view wx:if="{{!list.length && !loading}}" class="empty-state">暂无收藏内容</view>
</view>