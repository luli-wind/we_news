<view class="favorites-page">
  <view class="page-header">
    <view class="page-title">我的收藏</view>
    <view class="page-count" wx:if="{{list.length > 0}}">共 {{list.length}} 篇</view>
  </view>

  <view wx:if="{{loading}}" class="loading-state">加载中...</view>

  <block wx:elif="{{list.length > 0}}">
    <view wx:for="{{list}}" wx:key="id" class="fav-card" data-id="{{item.id}}" bindtap="goDetail">
      <image wx:if="{{item.coverUrl}}" class="fav-thumb" src="{{item.coverUrl}}" mode="aspectFill" lazy-load />
      <view class="fav-body">
        <view class="fav-title">{{item.title}}</view>
        <view wx:if="{{item.summary}}" class="fav-summary">{{item.summary}}</view>
      </view>
      <view class="fav-action" data-id="{{item.id}}" catchtap="unfavorite">
        <text>取消收藏</text>
      </view>
    </view>
  </block>

  <view wx:else class="empty-state">
    <view class="empty-icon">⭐</view>
    <view class="empty-title">暂无收藏</view>
    <view class="empty-sub">去首页浏览内容并收藏吧</view>
  </view>
</view>
