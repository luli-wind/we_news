.comments-page {
  min-height: 100vh;
  background: #f5f6f8;
  padding: 0 20rpx 40rpx;
}

/* ===== 头部 ===== */
.page-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 24rpx 4rpx 16rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #1a1a2e;
}

.page-count {
  font-size: 24rpx;
  color: #aaa;
}

/* ===== 评论卡片 ===== */
.comment-card {
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 14rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.comment-body {
  padding: 22rpx 24rpx 18rpx;
}

.comment-text {
  font-size: 30rpx;
  color: #1a1a2e;
  line-height: 1.7;
}

.comment-divider {
  height: 1rpx;
  background: #f3f4f6;
  margin: 0 24rpx;
}

.comment-footer {
  padding: 14rpx 24rpx 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* ===== 目标内容 ===== */
.comment-target {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
}

.target-icon {
  font-size: 22rpx;
  flex-shrink: 0;
}

.target-title {
  font-size: 24rpx;
  color: #555;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.3;
}

/* ===== 操作 ===== */
.comment-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.action-link {
  font-size: 24rpx;
  color: #2563eb;
  font-weight: 500;
}

.action-delete {
  font-size: 24rpx;
  color: #ef4444;
  font-weight: 500;
}

/* ===== 空状态 ===== */
.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-title {
  font-size: 30rpx;
  color: #555;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: #999;
}
