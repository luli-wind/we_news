.section-head {
  font-size: 46rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.comment-row {
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
  padding: 18rpx;
  display: flex;
  align-items: center;
}

.comment-main {
  flex: 1;
}

.comment-content {
  font-size: 36rpx;
  color: #1f2937;
  line-height: 1.5;
}

.comment-time {
  margin-top: 8rpx;
  color: #9ca3af;
  font-size: 24rpx;
}

.comment-thumb {
  width: 150rpx;
  height: 96rpx;
  border-radius: 8rpx;
  background: linear-gradient(135deg, #e5e7eb, #cbd5e1);
}