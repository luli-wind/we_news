page {
  --red: #e24b4b;
  --red-dark: #c53030;
  --bg: #f5f6f8;
  --card: #ffffff;
  --text: #1a1a2e;
  --text-secondary: #666;
  --text-muted: #999;
  --border: #eef0f3;
  --shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  --shadow-md: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  --radius: 16rpx;
  --radius-sm: 10rpx;

  background: var(--bg);
  color: var(--text);
  font-size: 28rpx;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", "Microsoft YaHei", sans-serif;
  -webkit-font-smoothing: antialiased;
}

/* 所有 tab 页面底部留出 tab-bar 空间 */
.tab-page {
  padding-bottom: 120rpx;
}
